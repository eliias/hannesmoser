#!/usr/bin/env bash
# author: Hannes Moser <hannes@impossiblearts.com>
#

# watch JavaScript files
javascript() {
  babel --optional runtime -L -e 1 -w -d ./dist ./src
}

# watch style files
styles() {
  nodemon --watch src/styles/*.less --ext less --exec 'npm run less'
}

# watch jade files
html() {
  jade --watch --out dist/ src/index.jade
}

# livereload
livereload() {
  npm run tinylr
}

# watch
watch() {
  ./bin/watcher
}

# server
server() {
  http-server ./dist
}

javascript &
pid[0]=$!
styles &
pid[1]=$!
html &
pid[2]=$!
livereload &
pid[3]=$!
watch &
pid[4]=$!
server &
pid[5]=$!
trap "kill ${pid[0]} ${pid[1]} ${pid[2]} ${pid[3]} ${pid[4]} ${pid[5]}; exit 1" INT
wait
