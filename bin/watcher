#!/usr/bin/env node

var gaze = require('gaze')
var request = require('request')

gaze('./dist/**/*.{js,css,html}', function(err) {
  if (err) {
    console.error(err)
  }

  this.on('all', function(event, filepath) {
    request('http://localhost:35729/changed?files=' + filepath, function(err) {
      if (err) {
        console.error(err)
      }
    })
  })
})
