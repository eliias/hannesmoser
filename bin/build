#!/usr/bin/env bash
# author: Hannes Moser <hannes@impossiblearts.com>
#

# compile to JavaScript
npm run clean &&
npm run init &&
npm run lint &&
npm run jade &&
npm run images &&
npm run css &&
npm run copy &&
browserify -d -e ./src/scripts/main.js -t babelify -p [minifyify --no-map] > ./dist/scripts/main.js
